.env
.env.local
__pycache__/
*.pyc
.venv/
.claude/

# Runtime state — tracked in git for Streamlit Cloud deployment.
# Auto-recalc updates this on app start when new activities exist.

# Streamlit secrets — contains cookies, API keys, feature flags.
# Use .streamlit/secrets.toml.example as the template.
.streamlit/secrets.toml

# Pytest cache
.pytest_cache/

# One-off exploration dumps (scripts/_*.json contain real athlete data).
# The scripts themselves are kept; their raw outputs are gitignored.
scripts/_*.json

# SQLite history — contains wellness data, TP sync state, weekly summaries.
# Schema lives in history_db.py (migrations run at app start).
history.db
history.db-*
