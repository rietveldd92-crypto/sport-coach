.env
.env.local
__pycache__/
*.pyc
.venv/
.claude/

# Runtime state — contains athlete data, load estimates, feedback logs.
# Use state.example.json as the schema template.
state.json

# Streamlit secrets — contains cookies, API keys, feature flags.
# Use .streamlit/secrets.toml.example as the template.
.streamlit/secrets.toml

# Pytest cache
.pytest_cache/

# One-off exploration dumps (scripts/_*.json contain real athlete data).
# The scripts themselves are kept; their raw outputs are gitignored.
scripts/_*.json
