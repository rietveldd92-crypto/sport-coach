# Copy this file to .streamlit/secrets.toml and fill in your values.
# secrets.toml is gitignored and will NOT be committed.
#
# Secrets declared here are accessible via config.get_secret("NAME") and
# take precedence over environment variables.

# ---- Feature flags ---------------------------------------------------------

# Master switch for the TrainingPeaks sync feature.
# Set to true only after you have a valid TP_AUTH_COOKIE and have tested
# the dry-run preview. Default is false so the UI renders without TP.
TP_SYNC_ENABLED = false

# ---- TrainingPeaks credentials --------------------------------------------

# TrainingPeaks uses an undocumented internal API. To authenticate:
#   1. Log in to https://trainingpeaks.com in your browser.
#   2. Open DevTools → Network tab → refresh the page.
#   3. Find any request to "tpapi.trainingpeaks.com/users/v3/token".
#   4. In the request headers, copy the "Production_tpAuth=..." cookie
#      value (everything from "Production_tpAuth=" up to the next ";").
#   5. Paste below, uncomment, and set TP_SYNC_ENABLED = true.
#
# This cookie is a session secret. Treat it like a password.
# Typical lifetime: days to weeks; refresh when the sidebar status goes red.
#
# TP_AUTH_COOKIE = "Production_tpAuth=PASTE_COOKIE_VALUE_HERE"
